{
  "name": "anima-mlx-speed",
  "state_dir": ".relentless-anima-mlx-speed",
  "env_files": [],
  "target_repo": {
    "path": "/Users/dustinpainter/Dev-Projects/mlx-experiments"
  },
  "command_env": {
    "PYTHONPATH": "/Users/dustinpainter/Dev-Projects/mlx-experiments/mflux/src",
    "MLX_SDPA_VJP_ATTENTION_BYTES_THRESHOLD": "900000000"
  },
  "worker_api": {
    "base_url": "https://openrouter.ai/api/v1",
    "api_key": "OPENROUTER_API_KEY",
    "model": "deepseek/deepseek-v4-pro",
    "temperature": 0.35,
    "max_tokens": 32768,
    "timeout_seconds": 1800,
    "max_retries": 3,
    "retry_backoff_base_seconds": 20.0,
    "skip_model_validation": true,
    "extra_headers": {
      "HTTP-Referer": "https://github.com/jaddai0/relentlessresearch",
      "X-Title": "RelentlessResearch Anima MLX Speed"
    },
    "provider_extras": {
      "top_p": 1.0,
      "reasoning": {
        "effort": "high"
      }
    }
  },
  "prompt": {
    "system": "prompts/relentless_system.md"
  },
  "loop": {
    "max_iterations": 80,
    "sleep_seconds": 3,
    "max_recent_iterations": 3,
    "max_observation_tail_chars": 1200,
    "max_recent_observation_chars": 8000,
    "max_git_status_chars": 5000,
    "max_diff_chars": 9000,
    "run_success_checks_every": 3,
    "stop_on_success": true
  },
  "external_reference_commands": {
    "every_iterations": 0,
    "commands": [
      {
        "name": "klein-speed-launcher",
        "command": "sed -n '340,455p' scripts/launch_flux2_dev_czepeku_lora.py",
        "timeout_seconds": 60
      },
      {
        "name": "steel-sdpa-vjp-note",
        "command": "sed -n '1,80p' mlx/backend/metal/kernels/steel/attn/kernels/README.md",
        "timeout_seconds": 60
      }
    ]
  },
  "canary_commands": {
    "every_iterations": 3,
    "commands": [
      {
        "name": "anima-help",
        "command": "mflux/.venv/bin/python scripts/train_anima_lora.py --help",
        "timeout_seconds": 120
      }
    ]
  },
  "provenance_commands": [
    {
      "name": "git-status",
      "command": "git status --short",
      "timeout_seconds": 60
    },
    {
      "name": "anima-speed-gate",
      "command": "python3 scripts/check_anima_speed_program.py",
      "timeout_seconds": 120
    }
  ],
  "compaction": {
    "enabled": true,
    "every_iterations": 10,
    "prompt_checkpoints": 1,
    "max_prompt_chars": 18000,
    "checkpoint_recent_iterations": 24,
    "checkpoint_result_tail_chars": 1200
  },
  "problem": {
    "title": "Anima MLX training speed program",
    "objective": "Optimize the Anima MLX LoRA trainer for memory-rich macOS training while preserving checkpoint resume, memory safety, and measurable success gates.",
    "known_facts": [
      "Anima lives under mflux/src/mflux/models/anima and the local model root is /Users/dustinpainter/Dev-Projects/Image-models/circlestone-labs/Anima.",
      "The training direction is memory-aggressive: prefer resident encoded caches and reduced recomputation when safe.",
      "Do not touch unrelated dirty Z-Image or caption-script files.",
      "Do not weaken scripts/check_anima_speed_program.py or remove MLX memory guard/watchdog coverage."
    ],
    "initial_hypotheses": [
      "Activation checkpointing and cache clearing frequency dominate steady-state step time after encoding is cached.",
      "Anima is small enough that measured mx.compile or compiled subgraphs may work even though Klein full-transformer compile did not.",
      "Further gains require attention backward/kernel work or reduced redundant mask/cast/transposition operations."
    ],
    "primary_strategy": "Make one bounded optimization at a time, preserve the static speed gate, then use short steady-state speed probes before touching kernels."
  },
  "editable_globs": [
    "mflux/src/mflux/models/anima/**/*.py",
    "mflux/tests/anima/**/*.py",
    "scripts/train_anima_lora.py",
    "scripts/launch_anima_lora.py",
    "scripts/run_anima_training_supervisor.py",
    "scripts/check_anima_speed_program.py",
    "docs/anima_speed_blueprint.md"
  ],
  "context_files": [
    "AGENTS.md",
    "docs/anima_speed_blueprint.md",
    "scripts/train_anima_lora.py",
    "scripts/launch_anima_lora.py",
    "scripts/run_anima_training_supervisor.py",
    "scripts/check_anima_speed_program.py",
    "mflux/src/mflux/models/anima/training/native_lora.py",
    "mflux/src/mflux/models/anima/model/anima_dit.py"
  ],
  "context_globs": [
    "mflux/src/mflux/models/anima/training/*.py",
    "mflux/tests/anima/*.py"
  ],
  "max_context_chars_per_file": 30000,
  "max_total_context_chars": 160000,
  "command_policy": {
    "allowed_prefixes": [
      "python3 ",
      "python ",
      "rg ",
      "sed ",
      "ls ",
      "find ",
      "git status",
      "git diff",
      "git log",
      "git show",
      "mflux/.venv/bin/python "
    ],
    "forbidden_substrings": [
      "rm -rf",
      "git reset --hard",
      "git checkout --",
      "pkill",
      "kill ",
      "OPENROUTER_API_KEY",
      "curl ",
      "wget ",
      "sudo ",
      "`",
      "$("
    ]
  },
  "validation_commands": [
    {
      "name": "anima-speed-gate",
      "command": "python3 scripts/check_anima_speed_program.py",
      "timeout_seconds": 120
    },
    {
      "name": "compile-anima",
      "command": "python3 -m compileall -q mflux/src/mflux/models/anima scripts/train_anima_lora.py scripts/launch_anima_lora.py scripts/run_anima_training_supervisor.py scripts/check_anima_speed_program.py",
      "timeout_seconds": 180
    }
  ],
  "success_commands": [
    {
      "name": "anima-speed-gate",
      "command": "python3 scripts/check_anima_speed_program.py",
      "timeout_seconds": 120
    },
    {
      "name": "anima-tests",
      "command": "mflux/.venv/bin/python -m pytest mflux/tests/anima -q",
      "timeout_seconds": 300
    }
  ]
}
