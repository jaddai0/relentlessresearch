# Worker-role env for the klein-flux2 campaign: routes the claude CLI worker
# to the GLM Coding Plan's Anthropic-compatible endpoint, while the supervisor
# (no role env of its own) keeps the normal first-party Claude login.
#
# Copy to config/klein-flux2-worker.env and fill in the token. The real file
# is gitignored (config/*.env) — never commit it.
#
# Z.ai documents this endpoint for Claude Code use with the Coding Plan.
# Verify once before launching a campaign:
#   set -a; source config/klein-flux2-worker.env; set +a
#   claude -p "Say READY and stop." --model glm-5.2 --output-format stream-json --verbose | tail -2

ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_AUTH_TOKEN=<your Z.ai coding-plan API key>

# If the endpoint rejects the --model name from the campaign config, uncomment
# and use these instead (Z.ai maps default model names server-side):
# ANTHROPIC_MODEL=glm-5.2
# ANTHROPIC_SMALL_FAST_MODEL=glm-4.7-flash
