# Kimi Coding Plan worker lane (ACTIVE for the klein-flux2 campaign).
# Routes the claude CLI worker to Moonshot's Anthropic-compatible coding
# endpoint. The endpoint serves exactly one model: kimi-for-coding
# ("K2.7 Code", 262K context, thinking-native, flat-fee subscription).
#
# Copy to config/klein-flux2-worker-kimi.env and fill in KIMI_API_KEY
# (sk-kimi-*, lives in Dev-Projects/env.env). Real file is gitignored.
#
# Verified end-to-end 2026-07-09: claude -p --output-format stream-json
# against this endpoint returns a clean result event with session id,
# and the endpoint accepts Claude Code's fingerprint headers.

ANTHROPIC_BASE_URL=https://api.kimi.com/coding
ANTHROPIC_AUTH_TOKEN=<sk-kimi-... coding plan key>
ANTHROPIC_MODEL=kimi-for-coding
ANTHROPIC_SMALL_FAST_MODEL=kimi-for-coding
ANTHROPIC_DEFAULT_HAIKU_MODEL=kimi-for-coding
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
API_TIMEOUT_MS=3000000
